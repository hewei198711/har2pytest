{
  "BASE_URLS": ["https://example.com/api"],
  "KILL_URLS": ["aliyuncs.com"],
  "SERVICE_MAPPING": {
    "api": "example_service"
  },
  "SWAGGER_DOC_URLS": {
    "example_service": "https://example.com/swagger"
  },
  "INVALID_PARAMS": ["rnd", "timestamp", "_t", "version", "sign"],
  "HEADERS_TO_INCLUDE": {
    "content-type": "application/json",
    "authorization": "bearer token"
  },
  "REQUIRED_HEADERS": {
    "content-type": "application/json",
    "content-length": "100",
    "origin": "https://example.com"
  },
  "PAGINATION_PARAMS": ["pageNum", "pageSize"],
  "DEFAULT_API_DIR": "apis",
  "TESTCASE_DIR": "testcases"
}